{
  "name": "scalzo-studio",
  "private": true,
  "packageManager": "npm@11.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "npm run dev --workspace @scalzo/web",
    "dev:local": "npm run supabase:start && npm run dev",
    "build": "npm run build --workspace @scalzo/web",
    "start": "npm run start --workspace @scalzo/web",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:status": "npx supabase status",
    "supabase:db:reset": "npx supabase db reset --local",
    "supabase:db:push": "npx supabase db push --linked",
    "supabase:db:push:local": "npx supabase db push --local",
    "supabase:migration:new": "npx supabase migration new",
    "supabase:db:diff": "npx supabase db diff",
    "supabase:admin:bootstrap:local": "node scripts/bootstrap-first-admin.mjs --local",
    "supabase:admin:bootstrap:linked": "node scripts/bootstrap-first-admin.mjs --linked",
    "supabase:types:local": "npx supabase gen types --local --lang typescript --schema public > apps/web/lib/supabase/database.types.ts",
    "supabase:types:linked": "npx supabase gen types --linked --lang typescript --schema public > apps/web/lib/supabase/database.types.ts",
    "lint": "npm run lint --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier . --check",
    "format:write": "prettier . --write",
    "check": "npm run format && npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.6",
    "@radix-ui/react-slot": "^1.2.2",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "latest",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.3.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "supabase": "^2.83.0",
    "tailwindcss": "^4.2.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5"
  }
}
